{
  "name": "react-nav-app1",
  "private": true,
  "version": "1.0.20",
  "type": "module",
  "scripts": {
    "gen:version": "node scripts/gen-version.cjs",
    "setup:hooks": "git config core.hooksPath .githooks",
    "prepare": "npm run setup:hooks",
    "predev": "npm run gen:version",
    "dev": "vite",
    "predev:lan": "npm run gen:version",
    "dev:lan": "vite --host 0.0.0.0 --port 5179",
    "free:backend-port": "sh -c 'lsof -ti:3001 | xargs kill -15 2>/dev/null || true'",
    "free:frontend-port": "sh -c 'lsof -ti:5179 | xargs kill -15 2>/dev/null || true'",
    "warmup:frontend": "node scripts/warmup-frontend.mjs",
    "predev:offline": "npm run gen:version",
    "prebuild": "npm run gen:version",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prepreview": "npm run gen:version",
    "preview": "vite preview",
    "projector:web": "vite preview --host 0.0.0.0 --port 5179 --strictPort",
    "backend": "node songs-api.cjs",
    "dev:offline": "npm run free:backend-port && npm run free:frontend-port && concurrently \"npm run backend\" \"npm run dev:lan\" \"npm run warmup:frontend\"",
    "projector:ws": "node scripts/projector-ws-server.mjs",
    "projector:start": "node scripts/projector-start.mjs",
    "projector:mac": "node scripts/projector-mac-start.mjs",
    "projector:kiosk": "node scripts/open-projector.mjs kiosk",
    "projector:fullscreen": "node scripts/open-projector.mjs fullscreen",
    "convert:supmus": "node scripts/convert-sup-mus-json.mjs",
    "projektor:ws": "npm run projector:ws",
    "projektor:start": "npm run projector:start",
    "projektor:mac": "npm run projector:mac",
    "projektor:kiosk": "npm run projector:kiosk",
    "projektor:kios": "npm run projector:kiosk",
    "projektor:fullscreen": "npm run projector:fullscreen",
    "update:projector": "bash scripts/update-projector.sh"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@fortawesome/fontawesome-svg-core": "^6.5.2",
    "@fortawesome/free-brands-svg-icons": "^6.5.2",
    "@fortawesome/free-regular-svg-icons": "^6.5.2",
    "@fortawesome/free-solid-svg-icons": "^6.5.2",
    "@fortawesome/react-fontawesome": "^0.2.1",
    "@mui/material": "^5.16.7",
    "@mui/styled-engine-sc": "^6.0.0-alpha.18",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-query": "^5.36.0",
    "axios": "^1.7.2",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "lodash.filter": "^4.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.2.1",
    "react-router-dom": "^6.23.1",
    "styled-components": "^6.1.12",
    "ws": "^8.18.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.0.0",
    "@types/lodash.filter": "^4.6.9",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}
